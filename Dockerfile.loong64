ARG BASE_IMAGE=debian:sid-slim
FROM --platform=linux/loong64 ${BASE_IMAGE}

ENV LANG=C.UTF-8
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends default-jre-headless && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY kkFileView.jar ./kkFileView.jar

EXPOSE 8012

ENTRYPOINT ["java", "-jar", "/app/kkFileView.jar"]